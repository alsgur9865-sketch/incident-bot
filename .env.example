# TrueFoundry AI Gateway 설정
TFY_API_KEY=tfy-your-pat-token-here
TFY_BASE_URL=https://gateway.truefoundry.ai
TFY_MODEL=incident-resilient/incident-resilient

# GitHub 연동 (Day 8 - Tool Calling)
# PAT 발급: https://github.com/settings/tokens (Generate new token classic, scope: public_repo)
  GITHUB_TOKEN=ghp_your_personal_access_token_here

# 분석할 repo (owner/repo 형식)
# 예: alsgur9865/내프로젝트  또는  fastapi/fastapi  또는  anthropics/claude-code
GITHUB_REPO=fastapi/fastapi
